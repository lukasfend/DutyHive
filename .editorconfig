# DutyHive — EditorConfig
# https://editorconfig.org
# Keeps line endings, indentation, encoding consistent across editors and OS.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown preserves trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab

# Windows batch files keep CRLF
[*.{bat,cmd}]
end_of_line = crlf

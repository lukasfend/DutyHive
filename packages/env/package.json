{
  "name": "@dutyhive/env",
  "version": "0.0.0",
  "private": true,
  "description": "Zod-validated environment variables. Throws at boot on missing/invalid env. Server/client split.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "echo 'lint placeholder'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests in @dutyhive/env'",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "3.24.1"
  }
}

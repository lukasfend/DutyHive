{
  "name": "@dutyhive/email",
  "version": "0.0.0",
  "private": true,
  "description": "React Email templates + Resend wrapper. Locale-aware. Dev → mailpit, prod → Resend.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./templates/*": "./src/templates/*.tsx"
  },
  "scripts": {
    "lint": "echo 'lint placeholder'",
    "typecheck": "tsc --noEmit",

  },
  "dependencies": {
    "@dutyhive/config": "workspace:*",
    "@dutyhive/env": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "nodemailer": "^8.0.7",
    "resend": "^6.12.2"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0"
  }

# DutyHive — pnpm configuration
# Hoisted node-linker keeps things compatible with tools that expect flat node_modules.
node-linker=hoisted

# Auto-install peers — reduces friction with shadcn/ui and React libraries.
auto-install-peers=true

# Strict peer deps off — many React 19 / Next 15 peers are noisy.
strict-peer-dependencies=false

# Use shared lockfile across workspace.
shared-workspace-lockfile=true

# Fail install if engines mismatch (keeps Node version consistent with .nvmrc).
engine-strict=true

# Faster install in CI, harmless locally.
prefer-frozen-lockfile=true

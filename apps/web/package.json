{
  "name": "@dutyhive/web",
  "version": "0.1.0-foundation.3",
  "private": true,
  "description": "DutyHive single Next.js app — routes all subdomains via the proxy convention to internal route groups.",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "echo 'unit/integration tests added in Phase 2/5'",
    "test:e2e": "echo 'playwright e2e in Phase 5'",
    "clean": "rm -rf .next .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@dutyhive/audit": "workspace:*",
    "@dutyhive/auth": "workspace:*",
    "@dutyhive/config": "workspace:*",
    "@dutyhive/db": "workspace:*",
    "@dutyhive/env": "workspace:*",
    "@dutyhive/i18n": "workspace:*",
    "@dutyhive/logger": "workspace:*",
    "@dutyhive/ui": "workspace:*",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.10.5",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "eslint": "9.18.0",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.0",
    "tailwindcss": "4.2.4",
    "typescript": "5.7.3"
  }
}

# DutyHive — apps/web environment variables (example)
# Copy to .env.local and fill in. .env.local is gitignored.
# See docs/guides/env-guide.md for explanations and rotation policy.

# --- Runtime ---
NODE_ENV=development

# --- Database (RLS-bound app role) ---
# Connects as dutyhive_app, BYPASSRLS=false. Every authenticated request runs
# inside a transaction with set_config('app.current_organization_id', …, true).
DATABASE_URL=postgresql://dutyhive_app:dev_app_password@localhost:5432/dutyhive_dev?schema=public

# Migration role (BYPASSRLS=true). Used by Prisma Migrate and by the
# schema-per-worker test setup. Never read by application code at runtime.
MIGRATE_DATABASE_URL=postgresql://dutyhive_migrate:dev_migrate_password@localhost:5432/dutyhive_dev?schema=public

# --- Better Auth ---
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-long-random-secret-min-32-chars-please-rotate
BETTER_AUTH_URL=http://lvh.me:3000

# --- Public client envs (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000
NEXT_PUBLIC_SITE_URL=http://lvh.me:3000

# --- Mail (dev: mailpit catches everything) ---
# Mailpit SMTP runs in docker-compose. Web UI: http://localhost:8025.
# Production swaps to Resend in @dutyhive/email backend selection.
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Resend (transactional + newsletter mail in production) ---
# Phase 4: leave empty locally — mailpit catches outgoing mail. Production: re_xxx
# RESEND_API_KEY=
RESEND_FROM=noreply@dutyhive.com

# --- Trigger.dev v3 ---
# Phase 5: leave empty locally for offline dev fallback
# TRIGGER_SECRET_KEY=

# --- Sentry ---
# Phase 5: leave empty locally
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Audit log salt ---
# Phase 2: rotate yearly, document rotation in env-guide.md
AUDIT_HASH_SALT=foundation-dev-salt-rotate-me-yearly

# --- Hetzner Object Storage (S3-compatible) ---
# Phase 6: leave empty until provisioned
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Logging ---
LOG_LEVEL=info

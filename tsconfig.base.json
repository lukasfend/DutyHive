{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* Language & target */
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",

    /* Module resolution */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": true,

    /* Emit (overridden per package) */
    "noEmit": true,
    "skipLibCheck": true,
    "incremental": true,

    /* Workspace path mapping */
    "baseUrl": ".",
    "paths": {
      "@dutyhive/config": ["packages/config/src/index.ts"],
      "@dutyhive/config/*": ["packages/config/src/*"],
      "@dutyhive/env": ["packages/env/src/index.ts"],
      "@dutyhive/env/*": ["packages/env/src/*"],
      "@dutyhive/logger": ["packages/logger/src/index.ts"],
      "@dutyhive/db": ["packages/db/src/index.ts"],
      "@dutyhive/db/*": ["packages/db/src/*"],
      "@dutyhive/auth": ["packages/auth/src/index.ts"],
      "@dutyhive/auth/*": ["packages/auth/src/*"],
      "@dutyhive/audit": ["packages/audit/src/index.ts"],
      "@dutyhive/i18n": ["packages/i18n/src/index.ts"],
      "@dutyhive/i18n/*": ["packages/i18n/src/*"],
      "@dutyhive/ui": ["packages/ui/src/index.ts"],
      "@dutyhive/ui/*": ["packages/ui/src/*"],
      "@dutyhive/email": ["packages/email/src/index.ts"],
      "@dutyhive/email/*": ["packages/email/src/*"],
      "@dutyhive/jobs": ["packages/jobs/src/index.ts"],
      "@dutyhive/jobs/*": ["packages/jobs/src/*"],
      "@dutyhive/pwa": ["packages/pwa/src/index.ts"],
      "@dutyhive/pwa/*": ["packages/pwa/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo", "coverage"]
}
